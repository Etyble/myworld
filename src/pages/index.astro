---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const blogPosts = await getCollection("blog", ({ data }) => !data.draft);
const writings = await getCollection("writings", ({ data }) => !data.draft);

const allPosts = [...blogPosts.map(p => ({ ...p, type: "blog" })), ...writings.map(w => ({ ...w, type: "writings" }))];
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latest = allPosts.slice(0, 4);
---

<Layout>
  <!-- Disclaimer overlay -->
  <div id="disclaimer" class="disclaimer-overlay">
    <div class="disclaimer-card">
      <button id="lang-toggle" class="lang-toggle">EN</button>
      <div class="disclaimer-icon">⚠</div>
      <h2><span class="cn">声明</span><span class="en">Disclaimer</span></h2>
      <div class="disclaimer-body">
        <p><span class="cn">本站所有内容仅代表<strong>个人观点</strong>，与任何组织、团体无关。</span><span class="en">All content represents <strong>personal views only</strong>, unrelated to any organization or group.</span></p>
        <p><span class="cn">本站不构成任何形式的行为建议。访问者基于本站内容做出的任何行为，<strong>均与本站及作者无关</strong>。</span><span class="en">This site does not constitute any form of behavioral advice. The author is <strong>not responsible</strong> for any actions taken based on its content.</span></p>
        <p><span class="cn">本站部分内容涉及<strong>前瞻性构想和未经验证的理论</strong>，请以批判性思维对待，保持独立思考。</span><span class="en">Some content involves <strong>speculative ideas and unverified theories</strong>. Approach with critical thinking.</span></p>
        <p class="cn">进入本站前，请确认：</p>
        <p class="en">Before entering, please confirm:</p>
        <ul class="cn">
          <li>你具有<strong>完全民事行为能力</strong></li>
          <li>你能够<strong>区分观点与事实</strong></li>
          <li>你理解<strong>理想主义言论</strong>不代表现实可行性</li>
          <li>你不会将这里的任何内容<strong>用于非法或有害目的</strong></li>
          <li>本站所有原创内容<strong>未经作者书面许可禁止转载、复制或二次使用</strong></li>
          <li>未经明确授权，<strong>禁止收集、存储或使用本站涉及的任何个人信息</strong></li>
        </ul>
        <ul class="en">
          <li>You have <strong>full civil capacity</strong></li>
          <li>You can <strong>distinguish opinion from fact</strong></li>
          <li>You understand that <strong>idealistic statements</strong> do not guarantee real-world feasibility</li>
          <li>You will not use any content here for <strong>illegal or harmful purposes</strong></li>
          <li>All original content <strong>may not be reproduced without written permission</strong></li>
          <li><strong>Collecting, storing, or using any personal information</strong> from this site is prohibited without explicit authorization</li>
        </ul>
        <p class="disclaimer-penalty"><span class="cn"><strong>违反后果：</strong>违反上述条款者，作者保留追究法律责任的权利，并有权采取技术手段限制其访问。侵权行为一经发现，将予以公开披露。</span><span class="en"><strong>Penalties:</strong> The author reserves the right to pursue legal action against violators and may restrict access through technical means. Infringements will be publicly disclosed upon discovery.</span></p>
        <p class="disclaimer-final"><span class="cn">保持理智在线，对自己负责。世界已经很乱了，不要因为我变得更乱。</span><span class="en">Stay rational. Take responsibility for yourself. The world is messy enough — don't make it worse because of me.</span></p>
      </div>
      <button id="disclaimer-btn" class="btn-primary"><span class="cn">我理解，进入网站</span><span class="en">I Understand, Enter</span></button>
    </div>
  </div>

  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <h1 class="title">
        <span class="gradient-text">Welcome!</span>
      </h1>
      <p class="welcome-text">
        欢迎来到Etyble的小窝，这里包含了我绝大部分的思考和想象，你可以在这里疯狂地窥探我（当然这是一些可公开的内容，吧？），总之欢迎你的到来，请注意保持理智哦。
      </p>
    </div>
    <div class="scroll-hint">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Latest</h2>
      <div class="card-grid">
        {latest.length > 0 ? (
          latest.map((post) => {
            const url = import.meta.env.BASE_URL + "/" + post.type + "/" + post.slug;
            return (
              <article class="card">
                <time>{post.data.date.toLocaleDateString("zh-CN")}</time>
                <span class="card-type">{post.type === "blog" ? "博客" : "碎碎念"}</span>
                <h3><a href={url}>{post.data.title}</a></h3>
                <p>{post.data.description || ""}</p>
              </article>
            );
          })
        ) : (
          <article class="card">
            <time>Coming soon</time>
            <h3>还没有文章</h3>
            <p>一些想法正在酝酿中。</p>
          </article>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%, rgba(124, 58, 237, 0.12), transparent),
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(167, 139, 250, 0.06), transparent);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    animation: rise 1s ease-out;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .greeting {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    margin-bottom: 24px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #a78bfa 0%, #7c3aed 40%, #6366f1 70%, #a78bfa 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .welcome-text {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.9;
  }

  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: bounce 2s ease-in-out infinite;
  }

  .scroll-hint span {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--text-muted), transparent);
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ---- Latest section ---- */
  .section {
    padding: 80px 0;
  }

  .section h2 {
    font-size: 1.5rem;
    margin-bottom: 32px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    transition: border-color 0.3s, transform 0.3s;
  }

  .card:hover {
    border-color: var(--accent-glow);
    transform: translateY(-2px);
  }

  .card time {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .card-type {
    display: inline-block;
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 100px;
    background: rgba(124, 58, 237, 0.12);
    color: var(--accent);
    margin-left: 8px;
    vertical-align: middle;
    letter-spacing: 0.05em;
  }

  .card h3 {
    margin: 8px 0;
    font-size: 1.1rem;
  }

  .card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ---- Disclaimer ---- */
  .disclaimer-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(8px);
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .disclaimer-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .disclaimer-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 40px;
    max-width: 560px;
    width: calc(100% - 48px);
    max-height: 85vh;
    overflow-y: auto;
    animation: rise 0.6s ease-out;
  }

  .disclaimer-icon {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 16px;
  }

  .lang-toggle {
    position: absolute;
    top: 16px;
    right: 20px;
    padding: 4px 12px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .lang-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Bilingual visibility */
  .en { display: none; }
  body.lang-en .en { display: inline; }
  body.lang-en .cn { display: none; }

  .disclaimer-card h2 {
    font-size: 1.3rem;
    text-align: center;
    margin-bottom: 24px;
    color: var(--accent);
  }

  .disclaimer-body {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .disclaimer-body p {
    margin-bottom: 10px;
  }

  .disclaimer-body ul {
    list-style: none;
    padding: 0;
    margin: 12px 0;
  }

  .disclaimer-body li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 6px;
  }

  .disclaimer-body li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .disclaimer-body strong {
    color: var(--text);
    font-weight: 600;
  }

  .disclaimer-penalty {
    margin-top: 16px;
    padding: 12px 16px;
    background: rgba(239, 68, 68, 0.08);
    border-left: 3px solid #ef4444;
    border-radius: 0 8px 8px 0;
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .disclaimer-penalty strong {
    color: #ef4444;
  }

  .disclaimer-final {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    color: var(--text) !important;
    text-align: center;
    font-size: 0.95rem;
  }

  .disclaimer-card .btn-primary {
    display: block;
    margin: 0 auto;
    padding: 18px 56px;
    font-size: 1.15rem;
    letter-spacing: 0.04em;
    border-radius: 100px;
  }
</style>

<script>
  const disclaimer = document.getElementById("disclaimer")!;
  const btn = document.getElementById("disclaimer-btn")!;
  const langBtn = document.getElementById("lang-toggle")!;
  let lang = "cn";

  if (sessionStorage.getItem("disclaimed")) {
    disclaimer.classList.add("hidden");
  }

  langBtn.addEventListener("click", () => {
    lang = lang === "cn" ? "en" : "cn";
    document.body.classList.toggle("lang-en", lang === "en");
    langBtn.textContent = lang === "cn" ? "EN" : "中";
  });

  btn.addEventListener("click", () => {
    sessionStorage.setItem("disclaimed", "1");
    disclaimer.classList.add("hidden");
  });
</script>

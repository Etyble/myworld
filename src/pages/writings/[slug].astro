---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const writings = await getCollection("writings", ({ data }) => !data.draft);
  return writings.map((w) => ({
    params: { slug: w.id },
    props: { writing: w },
  }));
}

const { writing } = Astro.props;
const { Content } = await writing.render();
---

<Layout title={writing.data.title + " — MyWorld"} description={writing.data.description}>
  <article class="writing">
    <div class="container">
      <p class="writing-date">{writing.data.date.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}</p>
      <h1>{writing.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .writing {
    padding: 80px 0;
  }

  .writing-date {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .writing h1 {
    font-size: 2.5rem;
    margin-bottom: 32px;
  }

  .prose {
    color: var(--text-muted);
    line-height: 1.9;
    font-size: 1rem;
    max-width: 640px;
  }

  .prose :global(p) {
    margin-bottom: 1.2em;
  }

  .prose :global(h2) {
    font-size: 1.3rem;
    color: var(--text);
    margin: 2em 0 0.8em;
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--accent);
  }
</style>

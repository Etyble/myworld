---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const writings = await getCollection("writings", ({ data }) => !data.draft);
writings.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="散文 — MyWorld" description="随笔、散文、碎片。">
  <section class="section">
    <div class="container">
      <h1 class="page-title">散文</h1>
      <p class="page-desc">随手写下的东西，不一定是完整的，但一定是真实的。</p>
      <div class="post-list">
        {writings.length > 0 ? (
          writings.map((w) => (
            <article class="post-item">
              <time>{w.data.date.toLocaleDateString("zh-CN")}</time>
              <h2><a href={import.meta.env.BASE_URL + "/writings/" + w.id}>{w.data.title}</a></h2>
              <p>{w.data.description}</p>
            </article>
          ))
        ) : (
          <div class="empty">还没有散文，但钢笔已经准备好了。</div>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .section { padding: 80px 0; }
  .page-title { font-size: 2.5rem; margin-bottom: 8px; }
  .page-desc { color: var(--text-muted); margin-bottom: 48px; }
  .post-list { display: flex; flex-direction: column; gap: 32px; }
  .post-item time { font-size: 0.8rem; color: var(--text-muted); }
  .post-item h2 { font-size: 1.3rem; margin: 4px 0; }
  .post-item p { color: var(--text-muted); font-size: 0.95rem; }
  .empty { color: var(--text-muted); font-style: italic; }
</style>

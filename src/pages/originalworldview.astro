---
import Layout from "../layouts/Layout.astro";
---

<Layout title="设定集 — MyWorld" description="世界设定与创作。">
  <section class="section">
    <div class="container">
      <h1 class="page-title">设定集</h1>
      <p class="page-desc">我的世界观、故事设定、角色档案。</p>
      <div class="empty">内容准备中，敬请期待。</div>
    </div>
  </section>
</Layout>

<style>
  .section { padding: 80px 0; }
  .page-title { font-size: 2.5rem; margin-bottom: 8px; }
  .page-desc { color: var(--text-muted); margin-bottom: 48px; }
  .empty { color: var(--text-muted); font-style: italic; }
</style>

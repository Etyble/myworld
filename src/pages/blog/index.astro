---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="博客 — MyWorld" description="工作进展与技术记录。">
  <section class="section">
    <div class="container">
      <h1 class="page-title">博客</h1>
      <p class="page-desc">工作进展、技术记录。</p>
      <div class="post-list">
        {posts.length > 0 ? (
          posts.map((post) => (
            <article class="post-item">
              <time>{post.data.date.toLocaleDateString("zh-CN")}</time>
              <h2><a href={import.meta.env.BASE_URL + "/blog/" + post.slug}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
            </article>
          ))
        ) : (
          <div class="empty">还没有文章。</div>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .section { padding: 80px 0; }
  .page-title { font-size: 2.5rem; margin-bottom: 8px; }
  .page-desc { color: var(--text-muted); margin-bottom: 48px; }
  .post-list { display: flex; flex-direction: column; gap: 32px; }
  .post-item time { font-size: 0.8rem; color: var(--text-muted); }
  .post-item h2 { font-size: 1.3rem; margin: 4px 0; }
  .post-item p { color: var(--text-muted); font-size: 0.95rem; }
  .empty { color: var(--text-muted); font-style: italic; }
</style>

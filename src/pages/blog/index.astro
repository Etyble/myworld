---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Blog — MyWorld" description="Writings and thoughts.">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Blog</h1>
      <div class="post-list">
        <article class="post-item">
          <time>2026.05.10</time>
          <h2><a href={import.meta.env.BASE_URL + "/blog/first"}>Getting Started</a></h2>
          <p>The first post on MyWorld. Why I built this and what to expect.</p>
        </article>
        <div class="empty">More posts coming soon.</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section {
    padding: 80px 0;
  }

  .page-title {
    font-size: 2.5rem;
    margin-bottom: 48px;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .post-item time {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-item h2 {
    font-size: 1.3rem;
    margin: 4px 0;
  }

  .post-item p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }
</style>

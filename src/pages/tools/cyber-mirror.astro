---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="赛博镜像 — MyWorld" description="回答关于今天的简单问题，生成你当下的人格图谱。照见自己。">
  <section class="mirror">
    <div class="container">
      <!-- ===== INTRO ===== -->
      <div id="intro" class="intro-screen">
        <p class="kicker">Cyber Mirror</p>
        <h1 class="title">赛博<span class="gradient-text">镜像</span></h1>
        <p class="subtitle">
          照见当下的自己。
        </p>
        <p class="desc">
          回答13个关于<strong>今天</strong>的简单问题——吃了几顿饭、睡得好不好、
          情绪如何、穿了什么颜色……然后算法生成一个只属于你的<strong>人格图谱</strong>。
        </p>
        <p class="desc-secondary">
          你不需要算命，你只需要<strong>看看今天的自己</strong>。<br/>
          命运在手里，不在镜子里。
        </p>
        <div class="features">
          <div class="feature">
            <span class="feature-icon">◇</span>
            <span>纯数据驱动，零主观判断</span>
          </div>
          <div class="feature">
            <span class="feature-icon">◇</span>
            <span>可视化图谱，可比较、可分享</span>
          </div>
          <div class="feature">
            <span class="feature-icon">◇</span>
            <span>你的数据不会被存储，刷新即消失</span>
          </div>
        </div>
        <button id="start-btn" class="btn-primary">开始观测</button>
        <p class="visitor-note">参与者代号：<strong>观测者</strong></p>
      </div>

      <!-- ===== QUESTIONNAIRE ===== -->
      <div id="questions" class="questions-screen" style="display:none;">
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>

        <div class="step" id="step-0">
          <p class="q-label">Q1</p>
          <h2>今天吃了几顿饭？</h2>
          <p class="q-hint">真实回答就好，这不是考试。</p>
          <div class="options" data-key="meals">
            <button data-value="0">0 顿</button>
            <button data-value="1">1 顿</button>
            <button data-value="2" class="selected">2 顿</button>
            <button data-value="3">3 顿</button>
            <button data-value="4">4 顿</button>
            <button data-value="5">5+ 顿</button>
          </div>
        </div>

        <div class="step" id="step-1" style="display:none;">
          <p class="q-label">Q2</p>
          <h2>好吃吗？</h2>
          <p class="q-hint">综合今天的饮食体验。</p>
          <div class="options scale" data-key="taste">
            <button data-value="1">😞 不太行</button>
            <button data-value="2">😐 一般般</button>
            <button data-value="3" class="selected">🙂 还不错</button>
            <button data-value="4">😋 挺好吃</button>
            <button data-value="5">🤤 超棒</button>
          </div>
        </div>

        <div class="step" id="step-2" style="display:none;">
          <p class="q-label">Q3</p>
          <h2>今天穿了什么颜色的上衣？</h2>
          <p class="q-hint">选最接近的颜色。</p>
          <div class="options colors" data-key="clothing">
            <button data-value="red" class="color-btn" style="--c:#ef4444;">红</button>
            <button data-value="orange" class="color-btn" style="--c:#f97316;">橙</button>
            <button data-value="yellow" class="color-btn" style="--c:#eab308;">黄</button>
            <button data-value="green" class="color-btn" style="--c:#22c55e;">绿</button>
            <button data-value="blue" class="color-btn" style="--c:#3b82f6;">蓝</button>
            <button data-value="purple" class="color-btn selected" style="--c:#8b5cf6;">紫</button>
            <button data-value="black" class="color-btn" style="--c:#6b7280;">黑</button>
            <button data-value="white" class="color-btn" style="--c:#e5e7eb;">白</button>
            <button data-value="gray" class="color-btn" style="--c:#9ca3af;">灰</button>
          </div>
        </div>

        <div class="step" id="step-3" style="display:none;">
          <p class="q-label">Q4</p>
          <h2>今天出门了吗？</h2>
          <div class="options" data-key="outdoor">
            <button data-value="yes">是，出门了</button>
            <button data-value="no" class="selected">没，一直在家</button>
          </div>
        </div>

        <div class="step" id="step-4" style="display:none;">
          <p class="q-label">Q5</p>
          <h2>今天和几个人交谈过？</h2>
          <p class="q-hint">包括线上和线下。</p>
          <div class="options" data-key="social">
            <button data-value="0">0 人，独自一人</button>
            <button data-value="1-2" class="selected">1-2 人</button>
            <button data-value="3-5">3-5 人</button>
            <button data-value="5+">很多人</button>
          </div>
        </div>

        <div class="step" id="step-5" style="display:none;">
          <p class="q-label">Q6</p>
          <h2>此刻的精力水平？</h2>
          <p class="q-hint">感受一下自己的身体状态。</p>
          <div class="options scale" data-key="energy">
            <button data-value="1">🔋 完全没电</button>
            <button data-value="2">😴 有点困</button>
            <button data-value="3" class="selected">😶 正常</button>
            <button data-value="4">💪 还不错</button>
            <button data-value="5">⚡ 精力爆棚</button>
          </div>
        </div>

        <div class="step" id="step-6" style="display:none;">
          <p class="q-label">Q7</p>
          <h2>今天有注意到天气吗？</h2>
          <div class="options" data-key="weather">
            <button data-value="yes-sunny">注意到了，是晴天 ☀️</button>
            <button data-value="yes-cloudy">注意到了，多云/阴天 ☁️</button>
            <button data-value="yes-rain">注意到了，下雨 🌧️</button>
            <button data-value="no" class="selected">完全没注意</button>
          </div>
        </div>

        <div class="step" id="step-7" style="display:none;">
          <p class="q-label">Q8</p>
          <h2>现在是什么时间段？</h2>
          <div class="options time" data-key="time">
            <button data-value="night">🌙 深夜</button>
            <button data-value="morning">🌅 早晨</button>
            <button data-value="forenoon">☀️ 上午</button>
            <button data-value="afternoon" class="selected">🌤️ 下午</button>
            <button data-value="evening">🌆 晚上</button>
          </div>
        </div>

        <div class="step" id="step-8" style="display:none;">
          <p class="q-label">Q9</p>
          <h2>昨晚睡得好吗？</h2>
          <p class="q-hint">睡眠是今天一切的底色。</p>
          <div class="options scale" data-key="sleep">
            <button data-value="1">😵 彻夜未眠</button>
            <button data-value="2">😣 很差</button>
            <button data-value="3" class="selected">😐 一般</button>
            <button data-value="4">🙂 还不错</button>
            <button data-value="5">😌 睡得很好</button>
          </div>
        </div>

        <div class="step" id="step-9" style="display:none;">
          <p class="q-label">Q10</p>
          <h2>今天大部分时间的情绪？</h2>
          <p class="q-hint">诚实面对自己。</p>
          <div class="options scale" data-key="mood">
            <button data-value="1">😢 低落</button>
            <button data-value="2">😟 焦虑</button>
            <button data-value="3" class="selected">😐 平静</button>
            <button data-value="4">🙂 愉悦</button>
            <button data-value="5">😆 充满热情</button>
          </div>
        </div>

        <div class="step" id="step-10" style="display:none;">
          <p class="q-label">Q11</p>
          <h2>今天运动了吗？</h2>
          <p class="q-hint">身体动起来，大脑才会跟上。</p>
          <div class="options" data-key="exercise">
            <button data-value="none" class="selected">完全没有</button>
            <button data-value="light">轻度（散步、伸展）</button>
            <button data-value="moderate">中度（快走、骑行）</button>
            <button data-value="intense">高强度（跑步、力量）</button>
          </div>
        </div>

        <div class="step" id="step-11" style="display:none;">
          <p class="q-label">Q12</p>
          <h2>现在是什么姿势？</h2>
          <p class="q-hint">感受一下身体和椅子的接触面。</p>
          <div class="options" data-key="posture">
            <button data-value="sitting" class="selected">坐着 🪑</button>
            <button data-value="standing">站着 🧍</button>
            <button data-value="lying">躺着 🛋️</button>
            <button data-value="moving">在移动中 🚶</button>
          </div>
        </div>

        <div class="step" id="step-12" style="display:none;">
          <p class="q-label">Q13</p>
          <h2>今天有接触大自然吗？</h2>
          <p class="q-hint">哪怕是从窗户看了一眼天空也算。</p>
          <div class="options" data-key="nature">
            <button data-value="none" class="selected">完全没有</button>
            <button data-value="sunlight">晒到了太阳 ☀️</button>
            <button data-value="green">看到了绿植 🌿</button>
            <button data-value="water">靠近了水边 🌊</button>
          </div>
        </div>

        <div class="step" id="step-13" style="display:none;">
          <p class="q-label">Q14</p>
          <h2>你在哪个城市？（可选）</h2>
          <p class="q-hint">
            一方水土养一方人。位置数据<strong>仅在本地处理</strong>，不会被上传或存储。
          </p>
          <div class="options" data-key="location">
            <button data-value="gps" class="gps-btn" id="gps-btn">📍 使用GPS自动获取</button>
            <button data-value="north">华北</button>
            <button data-value="northeast">东北</button>
            <button data-value="east">华东</button>
            <button data-value="central">华中</button>
            <button data-value="south">华南</button>
            <button data-value="southwest">西南</button>
            <button data-value="northwest">西北</button>
            <button data-value="skip" class="selected">跳过</button>
          </div>
          <p class="gps-status" id="gps-status"></p>
        </div>

        <div class="step" id="step-14" style="display:none;">
          <p class="q-label">Final</p>
          <h2>还有一个科学向的附加题</h2>
          <p class="q-hint">选填，但强烈推荐。基于大五人格简化量表。</p>
          <div class="big-five">
            <div class="bf-item">
              <span>我更享受与他人相处 &nbsp;→&nbsp; 我更享受独处</span>
              <input type="range" min="1" max="5" value="3" data-key="bf-extraversion" />
            </div>
            <div class="bf-item">
              <span>我倾向于按计划行事 &nbsp;→&nbsp; 我更喜欢随性而为</span>
              <input type="range" min="1" max="5" value="3" data-key="bf-conscientiousness" />
            </div>
            <div class="bf-item last">
              <span>我比较随和、不爱争执 &nbsp;→&nbsp; 我喜欢质疑和挑战</span>
              <input type="range" min="1" max="5" value="3" data-key="bf-agreeableness" />
            </div>
          </div>
        </div>

        <div class="nav-buttons">
          <button id="prev-btn" class="btn-secondary" style="display:none;">← 上一题</button>
          <button id="next-btn" class="btn-primary">下一题 →</button>
        </div>
      </div>

      <!-- ===== RESULT ===== -->
      <div id="result" class="result-screen" style="display:none;">
        <p class="kicker">观测完成</p>
        <h2>你的人格图谱</h2>
        <p class="result-sub">"观测者" <span id="observer-id"></span></p>

        <div id="persona-grid" class="persona-grid"></div>

        <div class="result-meta">
          <div class="meta-item">
            <span class="meta-label">Persona Hash</span>
            <span class="meta-value hash" id="persona-hash"></span>
          </div>
          <div class="meta-item">
            <span class="meta-label">类型名称</span>
            <span class="meta-value type-name" id="type-name"></span>
          </div>
        </div>

        <p class="result-desc" id="type-desc"></p>

        <div class="legend">
          <p>图谱解读维度：</p>
          <div class="legend-items">
            <span><i style="--lc:#ef4444;"></i>温度（快乐感）</span>
            <span><i style="--lc:#3b82f6;"></i>结构（秩序感）</span>
            <span><i style="--lc:#22c55e;"></i>活力（能量感）</span>
            <span><i style="--lc:#f59e0b;"></i>连接（社交感）</span>
            <span><i style="--lc:#8b5cf6;"></i>深度（内省感）</span>
          </div>
        </div>

        <button id="retry-btn" class="btn-secondary">重新观测</button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---- Mirror page global ---- */
  .mirror {
    padding: 80px 0 120px;
    min-height: 100vh;
  }

  .kicker {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #a78bfa 0%, #7c3aed 40%, #6366f1 70%, #a78bfa 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* ---- Intro ---- */
  .intro-screen {
    text-align: center;
    animation: rise 0.8s ease-out;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .intro-screen .subtitle {
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 24px;
    font-weight: 500;
  }

  .intro-screen .desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 520px;
    margin: 0 auto 12px;
  }

  .desc-secondary {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .features {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 36px;
  }

  .feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .feature-icon {
    color: var(--accent);
    font-size: 0.7rem;
  }

  .visitor-note {
    margin-top: 16px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* ---- Buttons ---- */
  .btn-primary {
    padding: 14px 40px;
    background: linear-gradient(135deg, #7c3aed, #6366f1);
    color: #fff;
    border: none;
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.3s;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(124, 58, 237, 0.4);
  }

  .btn-secondary {
    padding: 12px 32px;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ---- Questions ---- */
  .questions-screen {
    max-width: 560px;
    margin: 0 auto;
    animation: rise 0.4s ease-out;
  }

  .progress-bar {
    width: 100%;
    height: 3px;
    background: var(--border);
    border-radius: 999px;
    margin-bottom: 48px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 999px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .step h2 {
    font-size: 1.5rem;
    margin-bottom: 8px;
  }

  .q-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .q-hint {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .options {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 10px;
    margin-bottom: 32px;
  }

  .options button {
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
    text-align: center;
  }

  .options button:hover {
    border-color: var(--accent);
  }

  .options button.selected {
    border-color: var(--accent);
    background: rgba(124, 58, 237, 0.1);
    color: var(--accent);
  }

  .options.scale {
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  }

  .options.colors {
    grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
  }

  .options.colors button {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    padding: 0;
    background: var(--c);
    border: 3px solid transparent;
    font-size: 0.75rem;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    font-weight: 600;
  }

  .options.colors button:hover {
    border-color: #fff;
    transform: scale(1.1);
  }

  .options.colors button.selected {
    border-color: #fff;
    box-shadow: 0 0 20px var(--c);
    transform: scale(1.15);
  }

  .options.time {
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
  }

  /* ---- Big Five sliders ---- */
  .big-five {
    margin-bottom: 32px;
  }

  .bf-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }

  .bf-item span {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .bf-item input[type="range"] {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: var(--border);
    outline: none;
  }

  .bf-item input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
  }

  .gps-status {
    font-size: 0.8rem;
    color: var(--accent);
    margin-top: -24px;
    margin-bottom: 20px;
    min-height: 20px;
  }

  .gps-status.error {
    color: #ef4444;
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ---- Result ---- */
  .result-screen {
    text-align: center;
    animation: rise 0.6s ease-out;
  }

  .result-sub {
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  #observer-id {
    color: var(--accent);
    font-family: monospace;
    font-size: 0.9rem;
  }

  .persona-grid {
    display: inline-grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    margin-bottom: 32px;
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .persona-grid .cell {
    width: 48px;
    height: 48px;
    border-radius: 5px;
    transition: all 1.5s ease;
    animation: cell-pop 0.4s ease-out both;
  }

  @keyframes cell-pop {
    from {
      transform: scale(0);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .result-meta {
    display: flex;
    justify-content: center;
    gap: 48px;
    margin-bottom: 24px;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .meta-value {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .type-name {
    color: var(--accent);
  }

  .hash {
    font-family: "SF Mono", "Fira Code", monospace;
    letter-spacing: 0.05em;
    font-size: 1rem;
  }

  .result-desc {
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .legend {
    margin-bottom: 36px;
  }

  .legend p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .legend-items {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .legend-items span {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .legend-items i {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background: var(--lc);
  }

  @media (max-width: 600px) {
    .persona-grid .cell {
      width: 36px;
      height: 36px;
    }
    .result-meta {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>

<style is:global>
  @keyframes cell-pop {
    from {
      transform: scale(0);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script>
  // ---- State ----
  let currentStep = 0;
  const totalSteps = 15;
  const answers: Record<string, string> = {};

  // ---- DOM refs ----
  const intro = document.getElementById("intro")!;
  const questions = document.getElementById("questions")!;
  const result = document.getElementById("result")!;
  const progressFill = document.getElementById("progress-fill")!;
  const startBtn = document.getElementById("start-btn")!;
  const nextBtn = document.getElementById("next-btn")!;
  const prevBtn = document.getElementById("prev-btn")!;
  const retryBtn = document.getElementById("retry-btn")!;

  // ---- Start ----
  startBtn.addEventListener("click", () => {
    intro.style.display = "none";
    questions.style.display = "block";
    currentStep = 0;
    updateStep();
  });

  // ---- Navigation ----
  nextBtn.addEventListener("click", () => {
    saveCurrentStep();
    if (currentStep === totalSteps - 1) {
      generateResult();
      return;
    }
    currentStep++;
    updateStep();
  });

  prevBtn.addEventListener("click", () => {
    currentStep--;
    updateStep();
  });

  retryBtn.addEventListener("click", () => {
    result.style.display = "none";
    intro.style.display = "block";
    currentStep = 0;
    for (const k in answers) delete answers[k];
    document.querySelectorAll(".options button.selected").forEach((b) => b.classList.remove("selected"));
    document.querySelectorAll(".options button").forEach((b) => {
      if ((b as HTMLElement).dataset.value === "3") b.classList.add("selected");
      else b.classList.remove("selected");
    });
    document.querySelectorAll(".bf-item input").forEach((s) => {
      (s as HTMLInputElement).value = "3";
    });
  });

  // ---- Option selection ----
  document.querySelectorAll(".options").forEach((group) => {
    group.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button");
      if (!btn) return;
      // GPS button special handling
      if (btn.id === "gps-btn") {
        e.preventDefault();
        requestGPS();
        return;
      }
      group.querySelectorAll("button").forEach((b) => b.classList.remove("selected"));
      btn.classList.add("selected");
    });
  });

  // ---- GPS ----
  function requestGPS() {
    const statusEl = document.getElementById("gps-status")!;
    const gpsBtn = document.getElementById("gps-btn")!;

    if (!navigator.geolocation) {
      statusEl.textContent = "你的浏览器不支持GPS定位，请手动选择区域。";
      statusEl.className = "gps-status error";
      return;
    }

    statusEl.textContent = "正在请求位置权限...";
    statusEl.className = "gps-status";

    navigator.geolocation.getCurrentPosition(
      (pos) => {
        const lat = pos.coords.latitude.toFixed(2);
        const lng = pos.coords.longitude.toFixed(2);
        gpsBtn.dataset.value = "gps," + lat + "," + lng;
        gpsBtn.textContent = "📍 GPS已获取 (" + lat + ", " + lng + ")";

        // Select GPS button
        const group = gpsBtn.closest(".options")!;
        group.querySelectorAll("button").forEach((b) => b.classList.remove("selected"));
        gpsBtn.classList.add("selected");

        statusEl.textContent = "位置已获取，坐标仅在本地用于图谱生成。";
        statusEl.className = "gps-status";
      },
      (err) => {
        statusEl.textContent = "无法获取位置（" + (err.message || "用户拒绝或超时") + "），请手动选择区域。";
        statusEl.className = "gps-status error";
      },
      { timeout: 8000, maximumAge: 600000 }
    );
  }

  // ---- Step management ----
  function updateStep() {
    document.querySelectorAll(".step").forEach((s, i) => {
      (s as HTMLElement).style.display = i === currentStep ? "block" : "none";
    });

    const progress = ((currentStep + 1) / totalSteps) * 100;
    progressFill.style.width = progress + "%";

    prevBtn.style.display = currentStep === 0 ? "none" : "";

    if (currentStep === totalSteps - 1) {
      nextBtn.textContent = "生成图谱 ✦";
    } else {
      nextBtn.textContent = currentStep === 0 ? "开始 →" : "下一题 →";
    }

    const stepEl = document.getElementById("step-" + currentStep);
    if (stepEl) {
      (stepEl as HTMLElement).style.animation = "none";
      (stepEl as HTMLElement).offsetHeight;
      (stepEl as HTMLElement).style.animation = "rise 0.35s ease-out";
    }
  }

  function saveCurrentStep() {
    const stepEl = document.getElementById("step-" + currentStep);
    if (!stepEl) return;
    const group = stepEl.querySelector(".options") as HTMLElement | null;
    if (group) {
      const key = group.dataset.key!;
      const selected = group.querySelector("button.selected") as HTMLElement | null;
      if (selected) {
        answers[key] = selected.dataset.value!;
      }
    }
    if (currentStep === 14) {
      document.querySelectorAll(".bf-item input").forEach((input) => {
        const el = input as HTMLInputElement;
        answers[el.dataset.key!] = el.value;
      });
    }
  }

  // ---- Result generation ----
  function generateResult() {
    questions.style.display = "none";
    result.style.display = "block";

    const idSource = Object.values(answers).join("");
    const idHash = simpleHash(idSource);
    const id = idHash.toString(16).slice(0, 6).toUpperCase();
    document.getElementById("observer-id")!.textContent = "#" + id;

    const grid = document.getElementById("persona-grid")!;
    grid.innerHTML = "";
    const cells = generateGrid(answers);

    cells.forEach((color, i) => {
      const div = document.createElement("div");
      div.style.width = "48px";
      div.style.height = "48px";
      div.style.borderRadius = "5px";
      div.style.backgroundColor = color;
      div.style.transition = "all 1.5s ease";
      div.style.animation = "cell-pop 0.4s ease-out both";
      div.style.animationDelay = (i * 0.03) + "s";
      grid.appendChild(div);
    });

    const pHash = personaHash(answers);
    const typeName = hashToTypeName(pHash);
    const typeDesc = hashToDescription(pHash, answers);

    document.getElementById("persona-hash")!.textContent = pHash;
    document.getElementById("type-name")!.textContent = typeName;
    document.getElementById("type-desc")!.textContent = typeDesc;

    result.scrollIntoView({ behavior: "smooth" });
  }

  function simpleHash(s: string): number {
    let h = 0;
    for (let i = 0; i < s.length; i++) {
      h = ((h << 5) - h + s.charCodeAt(i)) | 0;
    }
    return Math.abs(h);
  }

  function seedFromAnswers(ans: Record<string, string>): number {
    return simpleHash(Object.values(ans).join("|"));
  }

  function mulberry32(seed: number): () => number {
    return function () {
      seed |= 0;
      seed = (seed + 0x6d2b79f5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  interface GridParams {
    hueBase: number;
    saturation: number;
    brightness: number;
    symmetry: number;
    density: number;
    noise: number;
    gradientBias: number;
    natureFactor: number;
    postureStability: number;
    locLatShift: number;
    locLngShift: number;
  }

  function getParams(ans: Record<string, string>): GridParams {
    const meals = parseInt(ans.meals || "2");
    const taste = parseInt(ans.taste || "3");
    const clothing = ans.clothing || "blue";
    const outdoor = ans.outdoor || "no";
    const social = ans.social || "1-2";
    const energy = parseInt(ans.energy || "3");
    const weather = ans.weather || "no";
    const time = ans.time || "afternoon";
    const sleep = parseInt(ans.sleep || "3");
    const mood = parseInt(ans.mood || "3");
    const exercise = ans.exercise || "none";
    const posture = ans.posture || "sitting";
    const nature = ans.nature || "none";
    const bfE = parseInt(ans["bf-extraversion"] || "3");
    const bfC = parseInt(ans["bf-conscientiousness"] || "3");
    const bfA = parseInt(ans["bf-agreeableness"] || "3");

    const clothingHue: Record<string, number> = {
      red: 0, orange: 25, yellow: 50, green: 120, blue: 210,
      purple: 270, black: 240, white: 0, gray: 220,
    };

    const timeHueShift: Record<string, number> = {
      night: 240, morning: 30, forenoon: 60, afternoon: 0, evening: 300,
    };

    const exerciseIntensity: Record<string, number> = {
      none: 0, light: 0.3, moderate: 0.6, intense: 1.0,
    };

    const natureOpenness: Record<string, number> = {
      none: 0.2, sunlight: 0.6, green: 0.7, water: 0.9,
    };

    // Location: low weight, subtle hue & noise shift
    const locStr = ans.location || "skip";
    let locLatShift = 0;
    let locLngShift = 0;
    if (locStr.startsWith("gps,")) {
      const parts = locStr.split(",");
      const lat = parseFloat(parts[1]) || 0;
      const lng = parseFloat(parts[2]) || 0;
      locLatShift = (lat / 90) * 15;  // -15° to +15° hue shift (north=cool, south=warm)
      locLngShift = (lng / 180) * 0.1; // ±0.1 noise shift
    } else {
      const regionShift: Record<string, [number, number]> = {
        north: [-10, 0], northeast: [-8, 0.05], east: [3, 0.04],
        central: [0, 0], south: [10, 0.03], southwest: [8, -0.04],
        northwest: [-5, -0.05], skip: [0, 0],
      };
      const [ls, ln] = regionShift[locStr] || [0, 0];
      locLatShift = ls;
      locLngShift = ln;
    }

    return {
      hueBase: (clothingHue[clothing] || 210 + (timeHueShift[time] || 0)) % 360,
      saturation: 0.4 + (taste / 5) * 0.3 + (mood / 5) * 0.2,
      brightness: 0.3 + (energy / 5) * 0.3 + (sleep / 5) * 0.25,
      symmetry: outdoor === "yes" ? 0.3 : 0.75,
      density: 0.55 + (meals / 5) * 0.3 + exerciseIntensity[exercise] * 0.15,
      noise: social === "0" ? 0.15 : social === "1-2" ? 0.4 : social === "3-5" ? 0.6 : 0.8,
      gradientBias: weather === "no" ? 0.5 : 0.15,
      natureFactor: natureOpenness[nature],
      postureStability: posture === "sitting" || posture === "lying" ? 0.7 : 0.3,
      locLatShift,
      locLngShift,
    };
  }

  function generateGrid(ans: Record<string, string>): string[] {
    const seed = seedFromAnswers(ans);
    const rand = mulberry32(seed);
    const p = getParams(ans);
    const size = 7;
    const cells: string[] = [];

    const center = (size - 1) / 2;

    for (let y = 0; y < size; y++) {
      for (let x = 0; x < size; x++) {
        let sy = y;
        let sx = x;
        if (rand() < p.symmetry) {
          if (x > center) sx = Math.round(center * 2 - x);
          if (y > center) sy = Math.round(center * 2 - y);
        }

        const dist = Math.sqrt((sx - center) ** 2 + (sy - center) ** 2) / center;

        // Density (bright vs dim cell)
        const densityRoll = rand();
        const densityThreshold = p.density * (1 - dist * 0.3);
        const isBright = densityRoll < densityThreshold;

        // Subtle adjustments
        const adjustedNoise = p.noise + p.locLngShift;
        const natureBoost = p.natureFactor * dist * 0.3;
        const postureDampen = p.postureStability < 0.5 ? rand() * 0.3 : 0;

        // Color
        const hueShift = (rand() - 0.5) * 60 * adjustedNoise + p.locLatShift;
        const hue = ((p.hueBase + hueShift) % 360 + 360) % 360;
        const edgeFactor = p.gradientBias > 0.3 ? dist * 1.5 : 1 - dist * adjustedNoise;

        const sat = isBright
          ? Math.min(1, Math.max(0.3, p.saturation * edgeFactor + rand() * 0.2 + natureBoost))
          : Math.min(0.2, p.saturation * 0.2 * edgeFactor);

        const bri = isBright
          ? Math.min(1, Math.max(0.3, p.brightness * (0.7 + rand() * 0.3) + postureDampen))
          : Math.min(0.15, p.brightness * 0.15);

        cells.push("hsl(" + Math.round(hue) + ", " + Math.round(sat * 100) + "%, " + Math.round(bri * 100) + "%)");
      }
    }

    return cells;
  }

  // ---- Canonical serialization + hashing ----
  function canonicalString(ans: Record<string, string>): string {
    const keys = Object.keys(ans).sort();
    return keys.map(k => k + "=" + ans[k]).join(";");
  }

  function personaHash(ans: Record<string, string>): string {
    const canonical = canonicalString(ans);
    const h = simpleHash(canonical);
    return h.toString(16).padStart(8, "0").slice(0, 8).toUpperCase();
  }

  // Each hex digit (0-15) selects from a pool of 16 words
  function hashToTypeName(hash: string): string {
    const essence: string[] = [
      "温暖的", "冷静的", "深邃的", "轻盈的", "内敛的", "精致的", "极简的", "空灵的",
      "热烈的", "淡然的", "孤独的", "疏离的", "自由的", "沉静的", "锋利的", "柔软的",
    ];
    const role: string[] = [
      "建筑师", "观察者", "星图师", "炼金术士", "诗人", "守望者", "漫游者", "幽灵",
      "棋手", "舞者", "烛火", "飞鸟", "园丁", "旅人", "云", "思考者",
    ];

    const e = parseInt(hash[0], 16);
    const r = parseInt(hash[7], 16);
    return essence[e] + role[r];
  }

  function hashToDescription(hash: string, ans: Record<string, string>): string {
    // Use hash to select from sentence pools
    const meals = parseInt(ans.meals || "2");
    const energy = parseInt(ans.energy || "3");
    const social = ans.social || "1-2";
    const outdoor = ans.outdoor || "no";
    const sleep = parseInt(ans.sleep || "3");
    const mood = parseInt(ans.mood || "3");
    const exercise = ans.exercise || "none";
    const nature = ans.nature || "none";
    const bfE = parseInt(ans["bf-extraversion"] || "3");

    const parts: string[] = [];

    if (meals >= 4) parts.push("你对生活中的美好事物有着敏锐的感知力");
    else if (meals <= 1) parts.push("你似乎不太被物质层面的需求所束缚");

    if (energy >= 4) parts.push("你的生命力正在向外辐射");
    else if (energy <= 2) parts.push("你正处在能量的低潮期，但这往往是内省的好时机");

    if (sleep >= 4) parts.push("充足的休息让你今天的底色明亮");
    else if (sleep <= 2) parts.push("疲惫可能是你今天隐藏的基调");

    if (mood >= 4) parts.push("今天你的情绪是向上的，世界看起来更友好");
    else if (mood <= 2) parts.push("情绪的低气压笼罩着你，但这也会过去");

    if (social === "0") parts.push("独处是你汲取能量的方式");
    else if (social === "5+") parts.push("你是人群中的连接者");

    if (outdoor === "yes") parts.push("你与世界的边界是开放的");
    else parts.push("你内心自有一个完整的世界");

    if (exercise !== "none") parts.push("身体的活动让你和现实保持了连接");
    else parts.push("也许明天可以试试动一动，哪怕只是散步");

    if (nature === "none") parts.push("也许可以抬头看看窗外");
    else parts.push("自然的痕迹今天曾在你生命中出现");

    if (bfE >= 4) parts.push("外界是舞台");
    else if (bfE <= 2) parts.push("内心是庙宇");

    if (parts.length === 0) parts.push("你是一个独特的存在，不符合任何简单标签");

    return parts.join("。") + "。";
  }
</script>

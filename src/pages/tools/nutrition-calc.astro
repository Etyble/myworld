---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="营养计算器 — MyWorld" description="看看今天吃够了没。">
  <section class="nc">
    <div class="container">
      <h1 class="title">营养<span class="gradient-text">计算器</span></h1>
      <p class="subtitle">选食物、估分量，看看今天还差什么。</p>

      <!-- ===== Top: Food Selector ===== -->
      <div class="panel panel-selector">
        <div class="filter-bar">
          <input type="text" id="search-input" class="search-input" placeholder="搜索食物..." />
          <div class="category-tabs" id="category-tabs">
            <button class="cat-tab active" data-cat="all">全部</button>
            <button class="cat-tab" data-cat="meat">肉类</button>
            <button class="cat-tab" data-cat="veg">蔬菜</button>
            <button class="cat-tab" data-cat="fruit">水果</button>
            <button class="cat-tab" data-cat="grain">主食</button>
            <button class="cat-tab" data-cat="bean">豆制品</button>
            <button class="cat-tab" data-cat="dairy">奶蛋</button>
          </div>
        </div>
        <div class="food-grid" id="food-grid"></div>
      </div>

      <!-- ===== Bottom: Selected Foods ===== -->
      <div class="panel panel-cart">
        <h2>已选食物</h2>
        <div class="cart-table-wrap">
          <table class="cart-table">
            <thead>
              <tr>
                <th>食物</th>
                <th class="col-qty">数量</th>
                <th class="col-unit">单位</th>
                <th class="col-cal">热量</th>
                <th class="col-p">蛋白质</th>
                <th class="col-f">脂肪</th>
                <th class="col-c">碳水</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="cart-body">
              <tr class="cart-empty">
                <td colspan="8">还没有选食物，在上面点选吧。</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Totals -->
        <div class="totals" id="totals"></div>
      </div>

      <p class="footnote">
        数据基于每100g可食部估算。模糊单位（碗/盘/个）为粗略换算，仅供参考。
        每日目标为成年人轻体力活动水平通用推荐值。
      </p>
    </div>
  </section>
</Layout>

<style is:global>
  .nc {
    padding: 60px 0 120px;
  }

  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #a78bfa 0%, #7c3aed 40%, #6366f1 70%, #a78bfa 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .subtitle {
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  /* ---- Panels ---- */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 20px;
  }

  .panel-selector {
    position: sticky;
    top: 64px;
    z-index: 5;
  }

  /* ---- Filter ---- */
  .filter-bar {
    margin-bottom: 20px;
  }

  .search-input {
    width: 100%;
    padding: 12px 16px;
    background: hsl(240 10% 8%);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    margin-bottom: 12px;
    transition: border-color 0.2s;
    -webkit-appearance: none;
    appearance: none;
  }

  .search-input:focus {
    border-color: var(--accent);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .category-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cat-tab {
    padding: 6px 16px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .cat-tab:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .cat-tab.active {
    background: rgba(124, 58, 237, 0.15);
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ---- Food grid ---- */
  .food-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 8px;
    max-height: 280px;
    overflow-y: auto;
    padding-right: 4px;
  }

  .food-grid::-webkit-scrollbar {
    width: 4px;
  }

  .food-grid::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }

  .food-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: hsl(240 10% 8%);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.88rem;
    font-family: inherit;
    color: var(--text);
  }

  .food-item:hover {
    border-color: var(--accent);
  }

  .food-item .emoji {
    margin-right: 6px;
  }

  .food-item .add-icon {
    color: var(--accent);
    font-weight: 600;
    font-size: 1.1rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .food-item:hover .add-icon {
    opacity: 1;
  }

  /* ---- Cart table ---- */
  .cart-table-wrap {
    overflow-x: auto;
    margin-bottom: 20px;
  }

  .cart-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .cart-table th {
    text-align: left;
    padding: 10px 8px;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .cart-table td {
    padding: 10px 8px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .cart-table .col-qty,
  .cart-table .col-unit,
  .cart-table .col-cal,
  .cart-table .col-p,
  .cart-table .col-f,
  .cart-table .col-c {
    text-align: right;
    white-space: nowrap;
  }

  .cart-empty td {
    text-align: center !important;
    color: var(--text-muted);
    padding: 32px 8px;
  }

  .qty-input {
    width: 72px;
    padding: 6px 8px;
    background: hsl(240 10% 8%);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-size: 0.88rem;
    text-align: center;
    font-family: inherit;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    -moz-appearance: textfield;
  }
  .qty-input::-webkit-inner-spin-button,
  .qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .qty-input:focus {
    border-color: var(--accent);
  }

  .unit-select {
    padding: 6px 10px;
    background: hsl(240 10% 8%);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-size: 0.82rem;
    font-family: inherit;
    cursor: pointer;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .rm-btn {
    padding: 5px 12px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .rm-btn:hover {
    border-color: #ef4444;
    color: #ef4444;
  }

  /* ---- Totals ---- */
  .totals {
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .total-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
  }

  .total-item {
    text-align: center;
  }

  .total-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }

  .total-bar-wrap {
    width: 100%;
    height: 6px;
    background: var(--border);
    border-radius: 999px;
    margin-bottom: 6px;
    overflow: hidden;
  }

  .total-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.4s ease, background 0.4s ease;
  }

  .total-values {
    font-size: 0.82rem;
    color: var(--text);
  }

  .total-values .target {
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .footnote {
    margin-top: 24px;
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.6;
    opacity: 0.7;
  }
</style>

<script>
  // ---- Food database (per 100g edible portion) ----
  interface FoodItem {
    id: string;
    name: string;
    emoji: string;
    cat: string;
    kcal: number;
    protein: number;
    fat: number;
    carbs: number;
    fiber: number;
    // Approx conversion for fuzzy units (grams per unit)
    perPiece?: number;  // 个 — used for naturally countable items (fruits, eggs, buns)
    perServing?: number; // 份 — one serving/portion (meat, fish)
    perBowl?: number;    // 碗
    perPlate?: number;   // 盘
  }

  const foods: FoodItem[] = [
    // Meat
    { id: "pork", name: "猪肉（瘦）", emoji: "🥩", cat: "meat", kcal: 143, protein: 20.3, fat: 6.2, carbs: 1.5, fiber: 0, perServing: 100 },
    { id: "beef", name: "牛肉", emoji: "🥩", cat: "meat", kcal: 125, protein: 19.9, fat: 4.2, carbs: 2.0, fiber: 0, perServing: 100 },
    { id: "chicken", name: "鸡胸肉", emoji: "🍗", cat: "meat", kcal: 133, protein: 19.4, fat: 5.0, carbs: 2.5, fiber: 0, perServing: 150 },
    { id: "lamb", name: "羊肉", emoji: "🍖", cat: "meat", kcal: 203, protein: 19.0, fat: 14.1, carbs: 0, fiber: 0, perServing: 80 },
    { id: "duck", name: "鸭肉", emoji: "🦆", cat: "meat", kcal: 240, protein: 15.5, fat: 19.7, carbs: 0.2, fiber: 0, perServing: 150 },
    { id: "fish", name: "草鱼", emoji: "🐟", cat: "meat", kcal: 113, protein: 16.6, fat: 5.2, carbs: 0, fiber: 0, perServing: 150 },
    { id: "shrimp", name: "虾仁", emoji: "🦐", cat: "meat", kcal: 93, protein: 18.6, fat: 0.8, carbs: 2.8, fiber: 0, perServing: 100 },
    { id: "egg", name: "鸡蛋", emoji: "🥚", cat: "dairy", kcal: 144, protein: 13.3, fat: 8.8, carbs: 2.8, fiber: 0, perPiece: 55 },
    { id: "sausage", name: "香肠", emoji: "🌭", cat: "meat", kcal: 508, protein: 24.1, fat: 40.7, carbs: 11.2, fiber: 0, perPiece: 50 },

    // Vegetables
    { id: "bokchoy", name: "小白菜", emoji: "🥬", cat: "veg", kcal: 15, protein: 1.5, fat: 0.3, carbs: 2.0, fiber: 0.8, perBowl: 200, perPlate: 300 },
    { id: "spinach", name: "菠菜", emoji: "🥬", cat: "veg", kcal: 23, protein: 2.6, fat: 0.3, carbs: 4.5, fiber: 1.7, perBowl: 200, perPlate: 300 },
    { id: "tomato", name: "番茄", emoji: "🍅", cat: "veg", kcal: 19, protein: 0.9, fat: 0.2, carbs: 4.0, fiber: 0.5, perPiece: 150 },
    { id: "cucumber", name: "黄瓜", emoji: "🥒", cat: "veg", kcal: 15, protein: 0.8, fat: 0.2, carbs: 2.9, fiber: 0.5, perPiece: 200 },
    { id: "broccoli", name: "西兰花", emoji: "🥦", cat: "veg", kcal: 34, protein: 2.8, fat: 0.4, carbs: 6.6, fiber: 2.6, perBowl: 200, perPlate: 300 },
    { id: "carrot", name: "胡萝卜", emoji: "🥕", cat: "veg", kcal: 41, protein: 1.0, fat: 0.2, carbs: 9.6, fiber: 1.2, perPiece: 100 },
    { id: "potato", name: "土豆", emoji: "🥔", cat: "veg", kcal: 76, protein: 2.0, fat: 0.2, carbs: 17.2, fiber: 0.7, perPiece: 200 },
    { id: "lettuce", name: "生菜", emoji: "🥬", cat: "veg", kcal: 13, protein: 1.0, fat: 0.2, carbs: 2.1, fiber: 0.5, perBowl: 200 },
    { id: "cabbage", name: "大白菜", emoji: "🥬", cat: "veg", kcal: 12, protein: 0.9, fat: 0.1, carbs: 2.2, fiber: 0.4, perBowl: 250, perPlate: 400 },
    { id: "eggplant", name: "茄子", emoji: "🍆", cat: "veg", kcal: 25, protein: 1.0, fat: 0.2, carbs: 5.9, fiber: 1.3, perPiece: 300 },
    { id: "corn", name: "玉米", emoji: "🌽", cat: "veg", kcal: 112, protein: 4.0, fat: 1.2, carbs: 22.8, fiber: 2.9, perPiece: 300 },

    // Fruits
    { id: "apple", name: "苹果", emoji: "🍎", cat: "fruit", kcal: 52, protein: 0.2, fat: 0.2, carbs: 13.5, fiber: 2.4, perPiece: 200 },
    { id: "banana", name: "香蕉", emoji: "🍌", cat: "fruit", kcal: 91, protein: 1.4, fat: 0.2, carbs: 22.0, fiber: 1.2, perPiece: 120 },
    { id: "orange", name: "橙子", emoji: "🍊", cat: "fruit", kcal: 47, protein: 0.8, fat: 0.2, carbs: 11.1, fiber: 0.6, perPiece: 200 },
    { id: "grape", name: "葡萄", emoji: "🍇", cat: "fruit", kcal: 69, protein: 0.5, fat: 0.2, carbs: 17.2, fiber: 0.4, perBowl: 300 },
    { id: "watermelon", name: "西瓜", emoji: "🍉", cat: "fruit", kcal: 31, protein: 0.5, fat: 0.1, carbs: 7.5, fiber: 0.2, perBowl: 400 },
    { id: "strawberry", name: "草莓", emoji: "🍓", cat: "fruit", kcal: 32, protein: 0.7, fat: 0.2, carbs: 7.1, fiber: 1.1, perBowl: 200 },
    { id: "kiwi", name: "猕猴桃", emoji: "🥝", cat: "fruit", kcal: 61, protein: 0.8, fat: 0.6, carbs: 14.5, fiber: 2.6, perPiece: 80 },

    // Grains
    { id: "rice", name: "米饭", emoji: "🍚", cat: "grain", kcal: 116, protein: 2.6, fat: 0.3, carbs: 25.9, fiber: 0.3, perBowl: 200 },
    { id: "noodle", name: "面条（煮）", emoji: "🍜", cat: "grain", kcal: 138, protein: 3.8, fat: 0.5, carbs: 28.5, fiber: 0.5, perBowl: 300 },
    { id: "bread", name: "吐司面包", emoji: "🍞", cat: "grain", kcal: 278, protein: 8.4, fat: 3.0, carbs: 55.3, fiber: 1.4, perPiece: 40 },
    { id: "dumpling", name: "饺子", emoji: "🥟", cat: "grain", kcal: 240, protein: 7.5, fat: 8.0, carbs: 33.5, fiber: 1.2, perPiece: 25, perPlate: 300 },
    { id: "baozi", name: "包子", emoji: "🫓", cat: "grain", kcal: 223, protein: 7.3, fat: 5.2, carbs: 37.0, fiber: 1.8, perPiece: 80 },
    { id: "oatmeal", name: "燕麦片", emoji: "🥣", cat: "grain", kcal: 379, protein: 13.5, fat: 6.5, carbs: 67.7, fiber: 5.3, perBowl: 50 },

    // Beans
    { id: "tofu", name: "豆腐", emoji: "🧈", cat: "bean", kcal: 76, protein: 8.1, fat: 3.7, carbs: 4.2, fiber: 0.4, perPiece: 300 },
    { id: "soymilk", name: "豆浆", emoji: "🥛", cat: "bean", kcal: 31, protein: 3.0, fat: 1.6, carbs: 1.2, fiber: 0.4, perBowl: 300 },
    { id: "edamame", name: "毛豆", emoji: "🫘", cat: "bean", kcal: 131, protein: 13.1, fat: 5.0, carbs: 10.5, fiber: 4.0, perBowl: 200 },

    // Dairy
    { id: "milk", name: "牛奶", emoji: "🥛", cat: "dairy", kcal: 54, protein: 3.0, fat: 3.2, carbs: 3.4, fiber: 0, perBowl: 250 },
    { id: "yogurt", name: "酸奶", emoji: "🍦", cat: "dairy", kcal: 72, protein: 2.5, fat: 2.7, carbs: 9.3, fiber: 0, perBowl: 200 },
  ];

  // Daily targets (adult, moderate activity)
  const targets = {
    kcal: 2000,
    protein: 65,
    fat: 60,
    carbs: 280,
    fiber: 25,
  };

  // Cart state: { [foodId]: { food: FoodItem, qty: number, unit: string } }
  const cart: Record<string, { food: FoodItem; qty: number; unit: string }> = {};

  // ---- Render food grid ----
  let currentCat = "all";
  let searchQuery = "";

  function renderFoodGrid() {
    const grid = document.getElementById("food-grid")!;
    let filtered = foods;

    if (currentCat !== "all") {
      filtered = filtered.filter(f => f.cat === currentCat);
    }
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      filtered = filtered.filter(f => f.name.toLowerCase().includes(q) || f.id.includes(q));
    }

    grid.innerHTML = filtered
      .map(
        (f) =>
          '<button class="food-item" data-id="' + f.id + '"><span><span class="emoji">' + f.emoji + '</span>' + f.name + '</span><span class="add-icon">+</span></button>'
      )
      .join("");

    // Click handler
    grid.querySelectorAll(".food-item").forEach((btn) => {
      btn.addEventListener("click", () => {
        addToCart((btn as HTMLElement).dataset.id!);
      });
    });
  }

  // ---- Cart operations ----
  function addToCart(foodId: string) {
    if (cart[foodId]) return; // already in cart
    const food = foods.find((f) => f.id === foodId);
    if (!food) return;
    cart[foodId] = { food, qty: 100, unit: "g" };
    renderCart();
    renderTotals();
  }

  function removeFromCart(foodId: string) {
    delete cart[foodId];
    renderCart();
    renderTotals();
  }

  function updateCartQty(foodId: string, qty: number) {
    if (cart[foodId]) {
      cart[foodId].qty = Math.max(1, qty);
      renderTotals();
    }
  }

  function updateCartUnit(foodId: string, unit: string) {
    const entry = cart[foodId];
    if (!entry) return;
    entry.unit = unit;

    // Convert approximate units
    const { food } = entry;
    if (unit === "g") {
      entry.qty = 100;
    } else if (unit === "piece" && food.perPiece) {
      entry.qty = 1;
    } else if (unit === "serving" && food.perServing) {
      entry.qty = 1;
    } else if (unit === "bowl" && food.perBowl) {
      entry.qty = 1;
    } else if (unit === "plate" && food.perPlate) {
      entry.qty = 1;
    }

    renderCart();
    renderTotals();
  }

  function getGrams(entry: { food: FoodItem; qty: number; unit: string }): number {
    if (entry.unit === "g") return entry.qty;
    if (entry.unit === "piece" && entry.food.perPiece) return entry.qty * entry.food.perPiece;
    if (entry.unit === "serving" && entry.food.perServing) return entry.qty * entry.food.perServing;
    if (entry.unit === "bowl" && entry.food.perBowl) return entry.qty * entry.food.perBowl;
    if (entry.unit === "plate" && entry.food.perPlate) return entry.qty * entry.food.perPlate;
    return entry.qty * 100; // fallback
  }

  function renderCart() {
    const tbody = document.getElementById("cart-body")!;
    const entries = Object.entries(cart);

    if (entries.length === 0) {
      tbody.innerHTML = '<tr class="cart-empty"><td colspan="8">还没有选食物，在上面点选吧。</td></tr>';
      return;
    }

    tbody.innerHTML = entries
      .map(([id, entry]) => {
        const { food, qty, unit } = entry;
        const grams = getGrams(entry);
        const mult = grams / 100;
        const hasPiece = food.perPiece != null;
        const hasServing = food.perServing != null;
        const hasBowl = food.perBowl != null;
        const hasPlate = food.perPlate != null;

        return '<tr>' +
          '<td>' + food.emoji + ' ' + food.name + '</td>' +
          '<td class="col-qty"><input class="qty-input" type="number" value="' + qty + '" min="1" data-id="' + id + '" data-field="qty" /></td>' +
          '<td class="col-unit"><select class="unit-select" data-id="' + id + '" data-field="unit">' +
            '<option value="g"' + (unit === "g" ? " selected" : "") + '>g</option>' +
            (hasServing ? '<option value="serving"' + (unit === "serving" ? " selected" : "") + '>份</option>' : '') +
            (hasPiece ? '<option value="piece"' + (unit === "piece" ? " selected" : "") + '>个</option>' : '') +
            (hasBowl ? '<option value="bowl"' + (unit === "bowl" ? " selected" : "") + '>碗</option>' : '') +
            (hasPlate ? '<option value="plate"' + (unit === "plate" ? " selected" : "") + '>盘</option>' : '') +
          '</select></td>' +
          '<td class="col-cal">' + Math.round(food.kcal * mult) + '</td>' +
          '<td class="col-p">' + (food.protein * mult).toFixed(1) + '</td>' +
          '<td class="col-f">' + (food.fat * mult).toFixed(1) + '</td>' +
          '<td class="col-c">' + (food.carbs * mult).toFixed(1) + '</td>' +
          '<td><button class="rm-btn" data-id="' + id + '" data-action="remove">✕</button></td>' +
          '</tr>';
      })
      .join("");

    // Bind events
    tbody.querySelectorAll(".qty-input").forEach((input) => {
      input.addEventListener("input", () => {
        const el = input as HTMLInputElement;
        updateCartQty(el.dataset.id!, parseInt(el.value) || 1);
      });
    });
    tbody.querySelectorAll(".unit-select").forEach((select) => {
      select.addEventListener("change", () => {
        const el = select as HTMLSelectElement;
        updateCartUnit(el.dataset.id!, el.value);
        renderCart();
        renderTotals();
      });
    });
    tbody.querySelectorAll(".rm-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        removeFromCart((btn as HTMLElement).dataset.id!);
      });
    });
  }

  function renderTotals() {
    const container = document.getElementById("totals")!;
    const entries = Object.values(cart);

    if (entries.length === 0) {
      container.innerHTML = "";
      return;
    }

    let totalKcal = 0, totalProtein = 0, totalFat = 0, totalCarbs = 0, totalFiber = 0;
    entries.forEach((entry) => {
      const mult = getGrams(entry) / 100;
      totalKcal += entry.food.kcal * mult;
      totalProtein += entry.food.protein * mult;
      totalFat += entry.food.fat * mult;
      totalCarbs += entry.food.carbs * mult;
      totalFiber += entry.food.fiber * mult;
    });

    const nutrients = [
      { label: "热量", value: totalKcal, target: targets.kcal, unit: "kcal", fmt: (v: number) => Math.round(v).toString() },
      { label: "蛋白质", value: totalProtein, target: targets.protein, unit: "g", fmt: (v: number) => v.toFixed(1) },
      { label: "脂肪", value: totalFat, target: targets.fat, unit: "g", fmt: (v: number) => v.toFixed(1) },
      { label: "碳水", value: totalCarbs, target: targets.carbs, unit: "g", fmt: (v: number) => v.toFixed(1) },
      { label: "膳食纤维", value: totalFiber, target: targets.fiber, unit: "g", fmt: (v: number) => v.toFixed(1) },
    ];

    container.innerHTML = '<div class="total-grid">' +
      nutrients
        .map((n) => {
          const pct = Math.min(100, (n.value / n.target) * 100);
          let color = "#22c55e";
          if (pct > 95) color = "#f59e0b";
          if (pct > 110) color = "#ef4444";

          return (
            '<div class="total-item">' +
            '<div class="total-label">' + n.label + '</div>' +
            '<div class="total-bar-wrap"><div class="total-bar-fill" style="width:' + pct + '%;background:' + color + ';"></div></div>' +
            '<div class="total-values">' + n.fmt(n.value) + ' ' + n.unit + ' <span class="target">/ ' + n.target + '</span></div>' +
            '</div>'
          );
        })
        .join("") +
      '</div>';
  }

  // ---- Filter & search ----
  document.getElementById("category-tabs")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".cat-tab");
    if (!btn) return;
    document.querySelectorAll(".cat-tab").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    currentCat = (btn as HTMLElement).dataset.cat!;
    renderFoodGrid();
  });

  const searchInput = document.getElementById("search-input")!;
  let searchTimer: ReturnType<typeof setTimeout>;
  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      searchQuery = (searchInput as HTMLInputElement).value.trim();
      renderFoodGrid();
    }, 200);
  });

  // ---- Init ----
  renderFoodGrid();
</script>

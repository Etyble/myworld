---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About — MyWorld">
  <section class="section">
    <div class="container">
      <h1 class="page-title">About</h1>
      <div class="prose">
        <p>Designer &amp; builder. I care about craft, detail, and making things that feel alive.</p>
        <p>This space is where I stash my design experiments, half-formed ideas, and things I want to remember. No algorithm, no noise — just my world.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section {
    padding: 80px 0;
  }

  .page-title {
    font-size: 2.5rem;
    margin-bottom: 32px;
  }

  .prose p {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 16px;
    max-width: 600px;
  }
</style>
